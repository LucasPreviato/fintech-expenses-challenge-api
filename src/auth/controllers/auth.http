@baseUrl = http://localhost:3333
@authToken = coloque-o-jwt-aqui

### Registrar usuario
POST {{baseUrl}}/auth/register
Content-Type: application/json

{
  "name": "John Doe",
  "email": "john@example.com",
  "password": "12345678"
}

### Login
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
  "email": "john@example.com",
  "password": "12345678"
}

### Usuario autenticado
GET {{baseUrl}}/auth/me
Authorization: Bearer {{authToken}}
